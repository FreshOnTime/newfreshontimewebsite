# Database
# Supabase Postgres / PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Authentication
# Required by lib/jwt.ts. Use a long random value in production.
JWT_SECRET="replace-with-a-long-random-secret"
JWT_ACCESS_EXPIRES="7d"
JWT_REFRESH_EXPIRES="30d"

# Public app URL used for verification and password reset links.
FRONTEND_URL="http://localhost:3000"

# Email, optional
SENDGRID_API_KEY=""
SENDGRID_FROM_EMAIL="hello@freshpick.lk"

# Azure Blob Storage, optional
AZURE_STORAGE_CONNECTION_STRING=""
AZURE_STORAGE_CONTAINER_NAME=""

# Analytics, optional
NEXT_PUBLIC_GA_ID=""
